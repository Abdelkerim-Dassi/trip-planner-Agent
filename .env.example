# Copy this file to .env and fill in your keys.

# Required — powers the agents (OpenAI chat model).
OPENAI_API_KEY=sk-...

# Optional — OpenAI organization id.
OPENAI_ORGANIZATION_ID=org-...

# Required — powers the web search tool (https://serper.dev).
SERPER_API_KEY=...

# Optional — override the default model (gpt-4o-mini) and temperature.
# TRIP_PLANNER_MODEL=gpt-4o-mini
# TRIP_PLANNER_TEMPERATURE=0.2
