# Copy this file to .env and fill in your keys.

# Which LLM provider powers the agents: "openai" (default) or "groq".
# Groq has a free tier (https://console.groq.com) — set this to "groq" to
# run end-to-end for free.
# VOYAGENT_PROVIDER=groq

# --- OpenAI (used when VOYAGENT_PROVIDER=openai, the default) ---
OPENAI_API_KEY=sk-...
# Optional — OpenAI organization id.
OPENAI_ORGANIZATION_ID=org-...

# --- Groq (used when VOYAGENT_PROVIDER=groq) ---
# Free key from https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Required — powers the web search tool (free tier at https://serper.dev).
SERPER_API_KEY=...

# Optional — override the default model and temperature.
# Default model is gpt-4o-mini (openai) or llama-3.3-70b-versatile (groq).
# VOYAGENT_MODEL=llama-3.3-70b-versatile
# VOYAGENT_TEMPERATURE=0.2

# Optional — Groq free-tier tuning (only used when provider=groq).
# Pause between agent steps to stay under the tokens-per-minute cap (set 0 on a
# paid tier), and how many times to wait out a 429 before giving up.
# GROQ_STEP_DELAY_SECONDS=5
# GROQ_NUM_RETRIES=8
